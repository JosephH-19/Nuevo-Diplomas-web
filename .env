# ============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ============================================
DB_USER=postgres
DB_PASSWORD=Admin1234
DB_HOST=localhost
DB_PORT=5432
DB_NAME=diplomas

# ============================================
# CONFIGURACIÓN DE SEGURIDAD
# ============================================
# Origenes permitidos para CORS (separados por coma)
# En producción reemplaza con tu dominio real
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# Clave secreta para JWT (genera una cadena aleatoria larga)
SECRET_KEY=cambia_esto_por_una_clave_secreta_muy_larga_y_aleatoria

# ============================================
# INSTRUCCIONES
# ============================================
# 1. Copia este archivo como ".env" (sin el .example)
# 2. Rellena los valores con tus datos reales
# 3. NUNCA subas el archivo .env al repositorio
